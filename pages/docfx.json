{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../SpessaSharp",
          "files": [
            "SpessaSharp.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      },
      {
        "src": "api",
        "files": [
          "**/*.yml"
        ],
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": [
          "public/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "custom-template"
    ],
    "globalMetadata": {
      "_appName": "SpessaSharp",
      "_appTitle": "SpessaSharp",
      "_enableSearch": true,
      "pdf": false,
      "_customCss": "public/main.css",
      "_appBaseURL": "/SpessaSharp/",
      "_appLogoPath": "public/spessasharp_logo_rounded.png",
      "_repositoryUrl": "https://github.com/Wh1teDuke/SpessaSharp",
      "iconLinks": [
        {
          "icon": "github",
          "href": "https://github.com/Wh1teDuke/SpessaSharp",
          "title": "GitHub"
        }
      ],
      "_gitContribute": {
        "repo": "https://github.com/Wh1teDuke/SpessaSharp",
        "branch": "master"
      }
    }
  }
}