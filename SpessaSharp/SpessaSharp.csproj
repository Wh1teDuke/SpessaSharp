<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <!-- Nuget -->
        <PackageId>SpessaSharp</PackageId>
        <Version>4.3.15</Version>
        <Version Condition="'$(Nightly)' != ''">$(Version)-nightly-$(Nightly)</Version>
        <Authors>WhiteDuke</Authors>
        <Description>SpessaSynth ported to C#</Description>
        <RepositoryUrl>https://github.com/Wh1teDuke/SpessaSharp</RepositoryUrl>
        <PackageProjectUrl>https://wh1teduke.github.io/SpessaSharp/</PackageProjectUrl>
        <PackageIcon>spessasharp_logo_rounded.jpg</PackageIcon>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageTags>midi;rmidi;synthesizer;dls;soundfont;audio;spessasynth</PackageTags>
        <PackageCopyright>Copyright (c) 2026 WhiteDuke</PackageCopyright>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <!-- warning CS1573: Parameter 'X' has no matching param tag in the XML comment for 'Y' (but other parameters do) -->
        <!-- warning CS1591: Missing XML comment for publicly visible type or member -->
        <NoWarn>1573;1591</NoWarn>

        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Library</OutputType>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <WarningsAsErrors>Nullable</WarningsAsErrors>
        <InvariantGlobalization>true</InvariantGlobalization>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <IsAotCompatible>true</IsAotCompatible>
        <IsTrimmable>true</IsTrimmable>
        <VerifyReferenceTrimCompatibility>true</VerifyReferenceTrimCompatibility>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.IO.Hashing" Version="10.0.9" />
        <PackageReference Include="System.Numerics.Tensors" Version="10.0.9" />

        <None Include="nuget\spessasharp_logo_rounded.jpg" Pack="true" PackagePath="\"/>
        <None Include="nuget\README.md" Pack="true" PackagePath="\" />
    </ItemGroup>
</Project>